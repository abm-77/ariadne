        2
      ]
    },
    {
      "name": "install_wheel",
      "action": "install_wheel",
      "inputs": [
        0,
        5
      ],
      "outputs": [
        6
      ],
      "after": [
        0,
        1,
        2
      ]
    },
    {
      "name": "test_wheel",
      "action": "test_wheel",
      "inputs": [
        0,
        6
      ],
      "outputs": [
        7
      ],
      "after": [
        0,
        1,
        2
      ]
    },
    {
      "name": "python_docs",
      "action": "python_docs",
      "inputs": [
        0,
        6
      ],
      "outputs": [
        8
      ],
      "after": [
        0,
        1,
        2
      ]
    },
    {
      "name": "python_coverage",
      "action": "python_coverage",
      "inputs": [
