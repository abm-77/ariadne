      "action": "refresh_profile",
      "inputs": [
        0
      ],
      "outputs": [
        10
      ],
      "after": [
        0,
        1,
        2
      ],
      "shell": {
        "script": "cargo build --release -p loom\n./target/release/loom profile github --workflow main.yml --runs 20 --out ci/profile.json",
        "capture": "NoCapture",
        "env": {
          "GH_TOKEN": "${{ secrets.GITHUB_TOKEN }}"
        }
      }
    },
    {
      "name": "commit_profile",
      "action": "commit_profile",
      "inputs": [
        0,
        10
      ],
      "after": [
        0,
        1,
        2
      ],
      "consequences": [
        0
      ]
    }
  ],
  "consequences": [
    {
      "name": "commit_profile.gitwrite",
      "kind": "GitWrite",
      "requires_approval": false
    }
  ],
  "inventory": {
    "id": "ariadne-ci",
    "actors": [
      {
        "id": "runner",
        "labels": [
          "ubuntu-latest"
        ],
        "capabilities": [
          "linux",
          "x86_64"
        ]
      }
    ],
    "implementations": [
      {
        "id": "git"
      },
      {
        "id": "rust",
        "version": "stable"
      },
      {
        "id": "cargo"
      },
      {
        "id": "python",
        "version": "3.12"
      },
      {
        "id": "maturin"
      },
      {
        "id": "ruff"
      },
      {
        "id": "pdoc"
      },
      {
        "id": "pytest"
      }
    ]
  },
  "triggers": [
    {
      "kind": "push",
      "branches": [
        "main"
      ]
    }
  ],
  "policies": {
    "install_dependencies": true,
    "objectives": [
      "dollar_cost",
      "critical_path"
    ]
  },
  "action_defs": [
    {
      "id": "checkout",
      "outputs": [
        {
          "name": "src",
          "ty": "SourceTree",
          "kind": "artifact"
        }
      ],
      "implementations": [
        {
          "kind": "semantic",
          "op": "scm.checkout"
        }
      ]
    },
    {
      "id": "rust_fmt",
      "inputs": [
        {
          "name": "src",
          "ty": "SourceTree",
          "kind": "artifact"
        }
      ],
      "implementations": [
        {
          "kind": "semantic",
          "op": "fmt.check",
          "using": "cargo"
        }
      ]
    },
    {
      "id": "python_fmt",
      "inputs": [
        {
          "name": "src",
          "ty": "SourceTree",
          "kind": "artifact"
        }
      ],
      "implementations": [
        {
          "kind": "semantic",
          "op": "fmt.check",
          "args": {
            "paths": [
              "frontends/python"
            ]
          },
          "using": "ruff"
        }
      ]
    },
    {
      "id": "build_loom",
      "inputs": [
        {
          "name": "src",
          "ty": "SourceTree",
          "kind": "artifact"
        }
      ],
      "outputs": [
        {
          "name": "loom",
          "ty": "Binary",
          "kind": "artifact"
        }
      ],
      "implementations": [
        {
          "kind": "semantic",
          "op": "build.binary",
          "args": {
            "package": "loom",
            "release": true
          },
          "prefer": [
            "cargo"
          ]
        }
      ]
    },
    {
      "id": "test_workspace",
      "inputs": [
        {
          "name": "src",
          "ty": "SourceTree",
          "kind": "artifact"
        },
        {
          "name": "loom",
          "ty": "Binary",
          "kind": "artifact"
        }
      ],
      "outputs": [
        {
          "name": "report",
          "ty": "TestReport",
          "kind": "artifact"
        }
      ],
      "implementations": [
        {
          "kind": "semantic",
          "op": "test.unit",
          "args": {
            "args": [
              "--workspace",
              "--",
              "--test-threads=4"
            ]
          },
          "prefer": [
            "cargo"
          ]
        }
      ]
    },
    {
      "id": "rust_docs",
      "inputs": [
        {
          "name": "src",
          "ty": "SourceTree",
          "kind": "artifact"
        }
      ],
      "outputs": [
        {
          "name": "docs",
          "ty": "DocsSite",
          "kind": "artifact"
        }
      ],
      "implementations": [
        {
          "kind": "semantic",
          "op": "docs.generate",
          "prefer": [
            "cargo"
          ]
        }
      ]
    },
    {
      "id": "rust_coverage",
      "inputs": [
        {
          "name": "src",
          "ty": "SourceTree",
          "kind": "artifact"
        }
      ],
      "outputs": [
        {
          "name": "coverage",
          "ty": "CoverageData",
          "kind": "artifact"
        }
      ],
      "implementations": [
        {
          "kind": "semantic",
          "op": "coverage.measure",
          "args": {
            "out": "lcov.info"
          },
          "prefer": [
            "cargo"
          ]
        }
      ]
    },
    {
      "id": "build_wheel",
      "inputs": [
        {
          "name": "src",
          "ty": "SourceTree",
          "kind": "artifact"
        }
      ],
      "outputs": [
        {
          "name": "wheel",
          "ty": "Wheel",
          "kind": "artifact"
        }
      ],
      "implementations": [
        {
          "kind": "semantic",
          "op": "build.python_wheel",
          "args": {
            "dir": "frontends/python",
            "release": true,
            "out": "../../dist"
          },
          "prefer": [
            "maturin",
            "ruff",
            "pdoc",
            "pytest"
          ]
        }
      ]
    },
    {
      "id": "install_wheel",
      "inputs": [
        {
          "name": "src",
          "ty": "SourceTree",
          "kind": "artifact"
        },
        {
          "name": "wheel",
          "ty": "Wheel",
          "kind": "artifact"
        }
      ],
      "outputs": [
        {
          "name": "env",
          "ty": "Wheel",
          "kind": "artifact"
        }
      ],
      "implementations": [
        {
          "kind": "semantic",
          "op": "package.install",
          "args": {
            "package": "dist/*.whl"
          },
          "using": "pip",
          "prefer": [
            "maturin",
            "ruff",
            "pdoc",
            "pytest"
          ]
        }
      ]
    },
    {
      "id": "test_wheel",
      "inputs": [
        {
          "name": "src",
          "ty": "SourceTree",
          "kind": "artifact"
        },
        {
          "name": "env",
          "ty": "Wheel",
          "kind": "artifact"
        }
      ],
      "outputs": [
        {
          "name": "report",
          "ty": "TestReport",
          "kind": "artifact"
        }
      ],
      "implementations": [
        {
          "kind": "semantic",
          "op": "test.unit",
          "args": {
            "paths": [
              "frontends/python/tests/"
            ],
            "args": [
              "-v"
            ]
          },
          "prefer": [
            "maturin",
            "ruff",
            "pdoc",
            "pytest"
          ]
        }
      ]
    },
    {
      "id": "python_docs",
      "inputs": [
        {
          "name": "src",
          "ty": "SourceTree",
          "kind": "artifact"
        },
        {
          "name": "env",
          "ty": "Wheel",
          "kind": "artifact"
        }
      ],
      "outputs": [
        {
          "name": "docs",
          "ty": "DocsSite",
          "kind": "artifact"
        }
      ],
      "implementations": [
        {
          "kind": "semantic",
          "op": "docs.generate",
          "args": {
            "package": "ariadne",
            "out": "frontends/python/docs"
          },
          "prefer": [
            "maturin",
            "ruff",
            "pdoc",
            "pytest"
          ]
        }
      ]
    },
    {
      "id": "python_coverage",
      "inputs": [
        {
          "name": "src",
          "ty": "SourceTree",
          "kind": "artifact"
        },
        {
          "name": "env",
          "ty": "Wheel",
          "kind": "artifact"
        }
      ],
      "outputs": [
        {
          "name": "coverage",
          "ty": "CoverageData",
          "kind": "artifact"
        }
      ],
      "implementations": [
        {
          "kind": "semantic",
          "op": "coverage.measure",
          "args": {
            "paths": [
              "frontends/python/tests"
            ],
            "package": "ariadne",
            "out": "py-coverage.xml"
          },
          "prefer": [
            "maturin",
            "ruff",
            "pdoc",
            "pytest"
          ]
        }
      ]
    },
    {
      "id": "refresh_profile",
      "inputs": [
        {
          "name": "src",
          "ty": "SourceTree",
          "kind": "artifact"
        }
      ],
      "outputs": [
        {
          "name": "profile",
          "ty": "ProfileData",
          "kind": "artifact"
        }
      ],
      "implementations": [
        {
          "kind": "shell",
          "run": "cargo build --release -p loom\n./target/release/loom profile github --workflow main.yml --runs 20 --out ci/profile.json",
          "capture": "NoCapture",
          "env": {
            "GH_TOKEN": "${{ secrets.GITHUB_TOKEN }}"
          }
        }
      ]
    },
    {
      "id": "commit_profile",
      "inputs": [
        {
          "name": "src",
          "ty": "SourceTree",
          "kind": "artifact"
        },
        {
          "name": "profile",
          "ty": "ProfileData",
          "kind": "artifact"
        }
      ],
      "consequences": [
        "GitWrite"
      ],
      "implementations": [
        {
          "kind": "semantic",
          "op": "scm.commit",
          "args": {
            "paths": [
              "ci/profile.json"
            ],
            "message": "[profile] refresh from CI runs [skip ci]",
            "push": true
          }
        }
      ]
    }
  ]
}