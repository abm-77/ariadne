{
  "name": "main_ci",
  "artifacts": [
    {
      "name": "checkout-src",
      "ty": "SourceTree",
      "producer": 0
    },
    {
      "name": "build_loom-loom",
      "ty": "Binary",
      "producer": 3,
      "path": "target/release/loom",
      "lifetime": "1h"
    },
    {
      "name": "test_workspace-report",
      "ty": "TestReport",
      "producer": 4,
      "path": "test-results.xml",
      "lifetime": "1h"
    },
    {
      "name": "rust_docs-docs",
      "ty": "DocsSite",
      "producer": 5,
      "path": "target/doc",
      "lifetime": "1h"
    },
    {
      "name": "rust_coverage-coverage",
      "ty": "CoverageData",
      "producer": 6,
      "path": "lcov.info",
      "lifetime": "1h"
    },
    {
      "name": "build_wheel-wheel",
      "ty": "Wheel",
      "producer": 7,
      "path": "dist/*.whl",
      "lifetime": "1h"
    },
    {
      "name": "install_wheel-env",
      "ty": "Wheel",
      "producer": 8
    },
    {
      "name": "test_wheel-report",
      "ty": "TestReport",
      "producer": 9,
      "path": "py-test-results.xml",
      "lifetime": "1h"
    },
    {
      "name": "python_docs-docs",
      "ty": "DocsSite",
      "producer": 10,
      "path": "frontends/python/docs",
      "lifetime": "1h"
    },
    {
      "name": "python_coverage-coverage",
      "ty": "CoverageData",
      "producer": 11,
      "path": "py-coverage.xml",
      "lifetime": "1h"
    },
    {
      "name": "refresh_profile-profile",
      "ty": "ProfileData",
      "producer": 12,
      "path": "ci/profile.json",
      "lifetime": "1h"
    }
  ],
  "action_calls": [
    {
      "name": "checkout",
      "action": "checkout",
      "outputs": [
        0
      ]
    },
    {
      "name": "rust_fmt",
      "action": "rust_fmt",
      "inputs": [
        0
      ]
    },
    {
      "name": "python_fmt",
      "action": "python_fmt",
      "inputs": [
        0
      ]
    },
    {
      "name": "build_loom",
      "action": "build_loom",
      "inputs": [
        0
      ],
      "outputs": [
        1
      ],
      "after": [
        0,
        1,
        2
      ]
    },
    {
      "name": "test_workspace",
      "action": "test_workspace",
      "inputs": [
        0,
        1
      ],
      "outputs": [
        2
      ],
      "after": [
        0,
        1,
        2
      ]
    },
    {
      "name": "rust_docs",
      "action": "rust_docs",
      "inputs": [
        0
      ],
      "outputs": [
        3
      ],
      "after": [
        0,
