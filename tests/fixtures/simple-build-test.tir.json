{
  "name": "Simple Build and Test",
  "artifacts": [
    {
      "name": "source",
      "ty": "SourceTree",
      "producer": 0
    },
    {
      "name": "binary",
      "ty": "Binary",
      "producer": 1
    },
    {
      "name": "test-report",
      "ty": "TestReport",
      "producer": 2
    }
  ],
  "action_calls": [
    {
      "name": "checkout",
      "action": "checkout",
      "outputs": [0],
      "shell": {
        "script": "git checkout .",
        "capture": "NoCapture"
      }
    },
    {
      "name": "build",
      "action": "build",
      "inputs": [0],
      "outputs": [1],
      "shell": {
        "script": "cargo build --release",
        "capture": "NoCapture"
      }
    },
    {
      "name": "test",
      "action": "test",
      "inputs": [1],
      "outputs": [2],
      "shell": {
        "script": "cargo test",
        "capture": "NoCapture"
      }
    }
  ],
  "inventory": {
    "id": "github",
    "actors": [
      {
        "id": "github-ubuntu",
        "labels": ["ubuntu-latest"]
      }
    ]
  },
  "policies": {
    "max_parallel_jobs": 2
  }
}
