{
  "workflow": {
    "name": "plan-assertions",
    "artifacts": [
      {
        "name": "src",
        "ty": "SourceTree",
        "producer": 0
      },
      {
        "name": "bin",
        "ty": "Binary",
        "producer": 1,
        "path": "target/release/app"
      }
    ],
    "action_calls": [
      {
        "name": "checkout",
        "action": "checkout",
        "outputs": [
          0
        ],
        "actor_constraints": [
          {
            "Specific": 0
          }
        ],
        "shell": {
          "script": "git checkout .",
          "capture": "NoCapture"
        }
      },
      {
        "name": "build",
        "action": "build",
        "inputs": [
          0
        ],
        "outputs": [
          1
        ],
        "consequences": [
          0
        ],
        "secrets": [
          "TOKEN"
        ],
        "actor_constraints": [
          {
            "Specific": 1
          }
        ],
        "shell": {
          "script": "make",
          "capture": "NoCapture"
        }
      },
      {
        "name": "deploy",
        "action": "deploy",
        "inputs": [
          1
        ],
        "consequences": [
          1
        ],
        "actor_constraints": [
          {
            "Specific": 0
          }
        ],
        "shell": {
          "script": "./deploy.sh",
          "capture": "NoCapture"
        }
      }
    ],
    "consequences": [
      {
        "name": "release",
        "kind": "PublishRelease",
        "requires_approval": true
      },
      {
        "name": "ship",
        "kind": "Deployment",
        "requires_approval": false
      }
    ],
    "inventory": {
      "id": "default",
      "actors": [
        {
          "id": "runner",
          "labels": [
            "ubuntu-latest"
          ]
        },
        {
          "id": "gpu-box",
          "labels": [
            "self-hosted"
          ],
          "capabilities": [
            "gpu"
          ]
        }
      ]
    },
    "policies": {
      "max_parallel_jobs": 4
    }
  },
  "event": {
    "push": {
      "branch": "main"
    }
  },
  "assertions": [
    {
      "assert": "has_consequence",
      "effect": "release"
    },
    {
      "assert": "consequence_requires_approval",
      "effect": "release"
    },
    {
      "assert": "consequence_gated",
      "effect": "release"
    },
    {
      "assert": "consequence_fired",
      "effect": "ship"
    },
    {
      "assert": "max_concurrent_deployments",
      "max": 1
    },
    {
      "assert": "max_jobs_with_capability",
      "capability": "gpu",
      "max": 2
    },
    {
      "assert": "max_parallel_jobs",
      "max": 10
    },
    {
      "assert": "selected_instruction",
      "op": "scm.checkout",
      "instruction": "local.semantic.fallback"
    },
    {
      "assert": "transfer_used",
      "artifact": "bin",
      "kind": "copy"
    },
    {
      "assert": "artifact_path",
      "artifact": "bin",
      "path": "target/release/app"
    },
    {
      "assert": "artifact_produced",
      "artifact": "bin"
    },
    {
      "assert": "secret_spoofed",
      "secret": "TOKEN"
    }
  ]
}