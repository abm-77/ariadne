{
  "workflow": {
    "name": "fork-pr",
    "artifacts": [
      {
        "name": "out",
        "ty": "Binary",
        "producer": 0
      }
    ],
    "actions": [
      {
        "name": "build",
        "op": "build",
        "outputs": [
          0
        ],
        "secrets": [
          "TOKEN"
        ],
        "shell": {
          "script": "echo \"TOKEN=[${TOKEN:-unset}]\"",
          "capture": "NoCapture"
        }
      }
    ],
    "actors": [
      {
        "name": "local",
        "labels": [
          "ubuntu-latest"
        ]
      }
    ],
    "policies": {}
  },
  "event": {
    "pull_request": {
      "fork": true
    }
  },
  "assertions": [
    {
      "assert": "run_passed"
    },
    {
      "assert": "secret_withheld",
      "secret": "TOKEN"
    },
    {
      "assert": "stdout_contains",
      "unit": "build",
      "text": "TOKEN=[unset]"
    }
  ]
}